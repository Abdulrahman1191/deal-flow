# Don't bake local dev artefacts into the image
.git
.gitignore
.env
.env.*
*.bak

# Frontend build artefacts and deps — generated by Stage 1 of Dockerfile
frontend/node_modules
frontend/dist
frontend/.vite

# Python caches and venvs
**/__pycache__
**/*.pyc
**/.pytest_cache
backend/.venv
backend/venv

# Local logs
*.log

# Documentation we don't need at runtime (keep README.md though)
PLATFORM_MIGRATION_PLAN.md
PORTFOLIO_INTELLIGENCE_PLAN.md
LLM_TUNING_PLAN.md
COPPER_BIDIRECTIONAL_SYNC.md
ROADMAP.md
DEPLOY.md
portfolio_template.xlsx
pitch-decks
