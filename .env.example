# =============================================================================
# Raed Deal Flow — env vars
# =============================================================================
# Copy this to `.env` for local development. In the platform deployment, these
# values are injected by the deploy form / platform-provided shared keys.
#
# Legend:
#   [PLATFORM]      — already provided by the platform; you do nothing
#   [DEPLOY-FORM]   — set this in the deploy form's env-vars panel
#   [KHALID]        — Khalid provides this (DB URL, webhook secret, etc.)
#   [LOCAL-ONLY]    — only relevant when running with `docker compose up`
# =============================================================================

# --- App identity ---
APP_NAME=deal-flow                              # [DEPLOY-FORM] subdomain stem
ENV=prod                                        # [DEPLOY-FORM] turns off /api/docs etc.

# --- Database ---
DATABASE_URL=                                   # [KHALID] postgresql+asyncpg://user:pass@host:5432/dbname

# --- Redis (in-compose) ---
REDIS_URL=redis://redis:6379/0                  # [LOCAL-ONLY default; platform usually overrides if shared]

# --- LLM providers ---
DEEP_SEEK_API=                                  # [DEPLOY-FORM] required, primary model
DEEPSEEK_MODEL=deepseek-chat                    # [LOCAL-ONLY] default fine

# Platform already injects ANTHROPIC_API_KEY and GEMINI_API_KEY — they're
# available as env vars if we want to use them.

# --- Web research ---
TAVILY_API_KEY=                                 # [DEPLOY-FORM] required

# --- Copper CRM (the platform injects COPPER_API_KEY; the rest are app-specific) ---
COPPER_WEBHOOK_SECRET=                          # [KHALID] for HMAC verification on /leads/ingest
COPPER_USER_EMAIL=                              # [DEPLOY-FORM]
COPPER_USER_ID=0                                # [DEPLOY-FORM]
COPPER_OPEN_STATUS_ID=0                         # [DEPLOY-FORM]
COPPER_UNQUALIFIED_STATUS_ID=0                  # [DEPLOY-FORM]
COPPER_PIPELINE_ID=0                            # [DEPLOY-FORM]
COPPER_PIPELINE_STAGE_ID=0                      # [DEPLOY-FORM]

# Copper custom-field IDs — once you've created the 9 custom fields per
# COPPER_BIDIRECTIONAL_SYNC.md §3, paste the IDs here to enable F8/F9 sync.
COPPER_CF_DRAFT_SUBJECT_ID=0                    # [DEPLOY-FORM]
COPPER_CF_DRAFT_BODY_ID=0                       # [DEPLOY-FORM]
COPPER_CF_DRAFT_TYPE_ID=0                       # [DEPLOY-FORM]
COPPER_CF_SUMMARY_ID=0                          # [DEPLOY-FORM]
COPPER_CF_APP_STATUS_ID=0                       # [DEPLOY-FORM]

# --- AWS S3 (pitch deck PDFs) ---
AWS_ACCESS_KEY_ID=                              # [DEPLOY-FORM] dedicated IAM user with S3 perms
AWS_SECRET_ACCESS_KEY=                          # [DEPLOY-FORM] paired with the above
AWS_REGION=ap-south-1                           # [DEPLOY-FORM]
S3_PITCH_DECK_BUCKET=                           # [DEPLOY-FORM] e.g. raed-prod-decks

# --- Owner / identity ---
OWNER_EMAIL=abdulrahman@raed.vc                 # [DEPLOY-FORM] gates Portfolio + Feedback tabs
ASSOCIATE_NAME=Abdulrahman                      # [DEPLOY-FORM] used in email drafts

# --- Behavioural flags ---
DISABLE_COPPER_SYNC=false                       # [DEPLOY-FORM] set true to pause periodic Copper polling
